<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="gsie_grados_form_view" model="ir.ui.view">
        <field name="name">gsie.grados.form.view</field>
        <field name="model">gsie.grados</field>
        <field name="arch" type="xml">
            <form string="Grados">
            <sheet>
                    <div>
                        <separator style="color:#009C96;font-style:bold; font-size: 20px" string="Datos"/>
                    </div>
                    <group colspan="4">
                        <group cols="2">
                            
                            <field name="name"/>
                

                        </group>
                        <group cols="2">
                            
                           
                          <field name="category_id"  decoration-bf="1"/>

                        </group>
                               
                    </group>

            </sheet>
            <div class="oe_chatter">                             
                <field name="message_ids" widget="mail_thread"/>
            </div>

            </form>
            

        </field>
    </record>

     <!--Vista de la tabla con los datos del objeto -->
    <record id="gsie_grados_tree_view" model="ir.ui.view">
        <field name="name">gsie.grados.tree_view</field>
        <field name="model">gsie.grados</field>
        <field name="arch" type="xml">
            <tree string="Grados" >

                <field name="name"  decoration-bf="1"/>
                <field name="category_id"  decoration-bf="1"/>

            </tree>
        </field>
    </record>

    <!-- search -->
    <record id="gsie_grados_search_view" model="ir.ui.view">
		<field name="name">gsie.grados.search_view</field>
		<field name="model">gsie.grados</field>
		<field name="arch" type="xml">
			<search string="Buscar">
				<field name="name"/>
			</search>
		</field>
	</record>

    <!-- Acción para abrir la view-->
    <record id="action_gsie_grados" model="ir.actions.act_window">
        <field name="name">Grados/niveles</field>
        <field name="res_model">gsie.grados</field>
         <field name="view_mode">tree,form</field>
    </record>


</odoo>