<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="school_meal_student_order_form" model="ir.ui.view">
        <field name="name">school_meal_student_order_form</field>
        <field name="model">school.meal.student.order</field>
        <field name="arch" type="xml">
            <form string="Summary report">
                <header>
                    <button 
                        name="getInfo" 
                        type="object" 
                        string="Get Orders"
                        class="btn-primary"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field 
                                name="barcode" 
                                required="1"
                            />
                            <field 
                                name="registration_date"
                                required="1"
                            />
                        </group>
                        <group>
                            <field 
                                name="student_id"
                                readonly="1"
                                force_save="1"
                                options="{'no_create':True, 'no_open':True}"
                            />
                        </group>
                    </group>
                    <notebook>
                        <page string="Student Orders">
                            <field 
                                name="school_meal_student_order_detail_ids"
                                readonly="1"
                                force_save="1"
                            >
                                <tree>
                                    <field name="num_order"/> 
                                    <field name="student_id"/>
                                    <field name="menu_id"/>
                                    <field 
                                        name="total_pay"
                                        sum="total"
                                    />
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!--detail form-->
    <record id="school_meal_student_order_detail_form2" model="ir.ui.view">
        <field name="name">school_meal_student_order_detail_form2</field>
        <field name="model">school.meal.student.order.detail</field>
        <field name="arch" type="xml">
            <form string="Student order">
                <header>
                     <button 
                        name="setDelivered" 
                        type="object" 
                        string="Delivered order"
                        states="Confirmed"
                        class="btn-primary"
                    />
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field 
                                name="num_order"
                                readonly="1"
                            />
                        </h1>
                    </div>
                    <group>
                        <group>
                           <field 
                                name="student_id"
                                readonly="1"
                                options="{'no_create':True, 'no_open':True}"
                            />

                            <field 
                                name="order_id"
                                invisible="1"
                                force_save="1"
                            />
                            <field
                                name="total_pay"
                                readonly="1"
                            />
                        </group>
                        <group>
                            <field 
                                name="menu_id"
                                readonly="1"
                                options="{'no_create':True, 'no_open':True}"
                            />
                        </group>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field 
                                name="school_meal_student_order_detail_products_ids"
                                readonly="1"
                            >
                                <tree>
                                    <field 
                                        name="category_id"
                                        options="{'no_create':True, 'no_open':True}"
                                    />
                                    <field
                                        name="product_id"
                                        options="{'no_create':True, 'no_open':True}"
                                    />
                                    <field name="description"/>
                                    <field name="ingredients"/>
                                    <field name="portion"/>
                                    <field name="size"/>
                                    <field name="price"/>
                                    <field name="quantity"/>
                                    <field 
                                        name="total"
                                        sum="total"
                                    />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!--detal form-->

    <record id="school_meal_student_order_tree" model="ir.ui.view">
        <field name="name">school_meal_student_order_tree</field>
        <field name="model">school.meal.student.order</field>
        <field name="arch" type="xml">
            <tree>
                <field name="student_id"/>
                <field name="registration_date"/>
            </tree>
        </field>
    </record>

    <record id="action_school_meal_student_order" model="ir.actions.act_window">
        <field name="name">Student Orders</field>
        <field name="res_model">school.meal.student.order</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>