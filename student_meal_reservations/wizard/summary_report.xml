<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="school_meal_summary_report_form" model="ir.ui.view">
        <field name="name">school_meal_summary_report_form</field>
        <field name="model">school.meal.summary.report</field>
        <field name="arch" type="xml">
            <form string="Summary report">
                <header>
                    <button 
                        name="getInfo" 
                        type="object" 
                        string="Get products"
                        class="btn-primary"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field 
                                name="registration_date" 
                                required="1"
                            />
                        </group>
                        <group>
                            <field 
                                name="date_to"
                                required="1"
                            />
                        </group>
                    </group>
                    <notebook>
                        <page string="Product details">
                            <field 
                                name="school_meal_summary_report_detail_ids"
                                readonly="1"
                            >
                                <tree>
                                    <field 
                                        name="item"
                                        options="{'no_open':True}"
                                    />
                                    <field
                                        name="unit"
                                        options="{'no_open':True}"
                                    />
                                    <field
                                        name="qty"
                                        options="{'no_open':True}"
                                    />
                                    <field
                                        name="price"
                                        sum="total"
                                    /> 
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_summary_report" model="ir.actions.act_window">
        <field name="name">Summary report</field>
        <field name="res_model">school.meal.summary.report</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>