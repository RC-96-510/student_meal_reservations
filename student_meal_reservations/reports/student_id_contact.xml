<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="student_id_contact_print" model="ir.actions.report">
        <field name="name">Student ID</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">student_meal_reservations.print_student_id_contact</field>
        <field name="report_file">student_meal_reservations.print_student_id_contact</field>
        <field name="print_report_name">'Student ID'</field>
        <field name="paperformat_id" ref="student_meal_reservations.student_id_paperformat" />
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_type">report</field>
    </record>

    <template id="print_student_id_contact">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="page" style="page-break-after: always;">
                    <table style="width:100%;" class="table-borderless">
                        <tr>
                            <td colspan="2" style="text-align:center;">
                                <span 
                                    style="font-family: 'Montserrat', 
                                        'League Spartan', 'Bebas Neue', sans-serif;
                                        font-weight: bold;
                                        font-stretch: condensed;
                                        font-size: 16pt;
                                        color: #B0202A;"
                                >HOME OF THE STALLIONS</span>
                            </td>
                        </tr>
                        <tr>
                            <td style="width:50%; text-align:center;">
                                <p style="margin-bottom:0px;">
                                    <img 
                                        t-att-src="'/student_meal_reservations/static/img/Logo_EC.png'" 
                                        style="width:130px; height:150px;"
                                    />
                                </p>
                                <!-- <p style="margin-bottom:0px; margin-top:-15px;">
                                    <span 
                                        style="
                                            font-family: 'Montserrat', 
                                                'League Spartan', 'Bebas Neue', sans-serif;
                                            font-weight: bold;
                                            font-stretch: condensed;
                                            font-size: 10pt;
                                            color: #B0202A;
                                            border-top: 2px solid #008080;
                                            border-bottom: 2px solid #008080;
                                            display: inline-block;
                                            width: 100%;
                                            text-align: center;"
                                    >BILINGUAL SCHOOL</span>
                                </p> -->
                                <p style="margin-bottom:0px; margin-top:-25px;">
                                    <span 
                                        style="font-family: 'Montserrat', 'League Spartan', 'Bebas Neue', sans-serif;
                                            font-weight: bold;
                                            font-stretch: condensed;
                                            font-size: 10pt;
                                            border-bottom: 2px solid #000;
                                            display: inline-block;
                                            width: 100%;
                                            text-align: center;
                                            text-transform: uppercase;"
                                        t-field="o.name"
                                    />
                                </p>
                            </td>
                            <td style="width:50%; text-align:right;">
                                <img 
                                    t-if="o.image_1920" 
                                    t-att-src="'data:image/png;base64,%s' % to_text(o.image_1920)" 
                                    style="width:150px; height:130px;"
                                    alt="Employee Image"
                                />
                                <p style="margin-bottom:0px; margin-top:0px;text-align:center;">
                                    <span 
                                        style="font-family: 'Montserrat', 'League Spartan', 'Bebas Neue', sans-serif;
                                            font-weight: bold;
                                            font-stretch: condensed;
                                            font-size: 10pt;
                                            color: #008080;"
                                        t-field="o.codigo_estudiante"
                                    />
                                </p>
                                <img 
                                    t-if="o.codigo_estudiante" 
                                    t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', o.codigo_estudiante, 600, 120)" 
                                    style="height:20pt; width:100%;"
                                />
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>

</odoo>
