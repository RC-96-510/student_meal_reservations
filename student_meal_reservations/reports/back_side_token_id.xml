<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="back_side_token_id_print" model="ir.actions.report">
        <field name="name">Back Side Token ID</field>
        <field name="model">gsie.family</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">student_meal_reservations.print_back_side_token_id</field>
        <field name="report_file">student_meal_reservations.print_back_side_token_id</field>
        <field name="print_report_name">'Back Side Token ID'</field>
        <field name="paperformat_id" ref="student_meal_reservations.token_id_paperformat" />
        <field name="binding_model_id" ref="gsie_english_castle_module.model_gsie_family"/>
        <field name="binding_type">report</field>
    </record>

    <template id="print_back_side_token_id">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="page" style="page-break-after: always;">
                    <br/>
                    <table style="width:100%;" class="table-borderless">
                        <tr>
                            <td style="width:100%; text-align:center;">
                                <div style="margin:0; padding:0; line-height:0;">
                                    <img 
                                        t-att-src="'/student_meal_reservations/static/img/back_token.png'" 
                                        style="width:150px; height:250px;"
                                    />
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td style="width:100%;">
                                <span
                                    style="font-family: 'Montserrat', 
                                        'League Spartan', 'Bebas Neue', sans-serif;
                                        font-weight: bold;
                                        font-size: 11pt;
                                        color: #B0202A;
                                        display: block;
                                        text-align: center;"
                                >HOME OF THE STALLIONS</span>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>

</odoo>
