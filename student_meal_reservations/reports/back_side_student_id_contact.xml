<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="back_side_student_id_contact_print" model="ir.actions.report">
        <field name="name">Back Side Student ID</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">student_meal_reservations.print_back_side_student_id_contact</field>
        <field name="report_file">student_meal_reservations.print_back_side_student_id_contact</field>
        <field name="print_report_name">'Student ID'</field>
        <field name="paperformat_id" ref="student_meal_reservations.student_id_paperformat" />
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_type">report</field>
    </record>

    <template id="print_back_side_student_id_contact">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="page" style="page-break-after: always;">
                    <table style="width:100%;" class="table-borderless">
                        <tr>
                            <td style="
                                font-family: 'Montserrat', 'League Spartan', 'Bebas Neue', sans-serif;
                                font-weight: bold;
                                font-size: 8pt;
                                padding-left:10px;
                                padding-right:10px;
                                padding-bottom:10px;"
                            >
                                <p style="margin-bottom:0px;">
                                    -This card must be carried while on school property.
                                </p>
                                <p style="margin-top:0px;">
                                    -This card is non-transferable and may only be used by 
                                    the student whose name appears on the front.
                                </p> 
                                <p>
                                    If found, please return to the main office immediately.
                                </p>
                                <p style="margin-bottom:0px;">
                                    +504 2763-8624
                                </p>
                                <p style="margin-bottom:0px; margin-top:0px;">
                                    informacion@english-castle.com
                                </p>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>

</odoo>
