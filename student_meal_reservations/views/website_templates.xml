<odoo>
  <template id="menu_page_template" name="Elliot's Menu Page" inherit_id="website.layout">
    <xpath expr="//main" position="inside">
      <section class="container mt-4">
        <h2 class="text-center mb-4">🍽️ Elliot's Shack – Monthly Meal Menu</h2>
        <table width="100%">
          <tr>
            <td>
              <p>Welcome, <t t-esc="request.env.user.name"/>!</p>
            </td>
            <td>
              <div class="form-group">
                <label for="menu_id">Select Menu</label>
                <select name="menu_id" id="menu_id" class="form-control" required="1">
                  <option value="">-- Choose Menu --</option>
                  <t t-foreach="menus" t-as="menu">
                    <option t-att-value="menu.id" t-esc="menu.name"/>
                  </t>
                </select>
              </div>
            </td>
          </tr>
        </table>
        
