<odoo>

  <record id="view_school_menu_kanban" model="ir.ui.view">
    <field name="name">view.school.menu.kanban</field>
    <field name="model">school.menu</field>
    <field name="arch" type="xml">
        <kanban>
            <field name="name"/>
            <field name="state"/>

            <templates>
                <t t-name="kanban-box">
                    <!-- Hace que el registro sea clickeable -->
                    <div class="o_kanban_record oe_kanban_global_click">
                        <div class="o_kanban_details">
                            <strong>
                                <field name="name"/>
                            </strong>
                            <div>
                                <field name="state"/>
                            </div>
                        </div>
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
</record>

  <record id="view_school_menu_tree" model="ir.ui.view">
    <field name="name">view_school_menu_tree</field>
    <field name="model">school.menu</field>
    <field name="arch" type="xml">
      <tree string="Menus">
        <field name="name"/>
        <field name="state"/>
      </tree>
    </field>
  </record>

  <record id="view_school_menu_form" model="ir.ui.view">
    <field name="name">view_school_menu_form</field>
    <field name="model">school.menu</field>
    <field name="arch" type="xml">
      <form string="Menus">
        <header>
          <button 
            name="availableMenu" 
            type="object" 
            string="Available"
            states="Draft"
            class="btn-primary"
          />

          <button 
            name="draftMenu" 
            type="object" 
            string="Back to draft"
            states="Available,Unavailable"
          />

             <button 
              name="UnavailableMenu" 
              type="object" 
              string="Unavailable"
              states="Available"
              class="btn-primary"
            />
					<field name="state" widget="statusbar" />
        </header>
        <sheet>
          <div class="oe_title">
              <h1>
                  <field 
                    name="name"
                    attrs="{'readonly':[('state', 'in' , ('Available', 'Unavailable'))]}"
                  />
              </h1>
          </div>
          <group>
            <group>
              <field 
                name="date_from"
                required="1"
                attrs="{'readonly':[('state', 'in' , ('Available', 'Unavailable'))]}"
              />

              <div class="form-group">
                <label for="pdf_file" class="form-label">Archivo (PDF o Imagen)</label>
                <field
                  name="pdf_file"
                  widget="binary"
                  accept="image/*,.pdf"
                  attrs="{'readonly':[('state', 'in' , ('Available', 'Unavailable'))]}"
                  help="Adjunta un archivo PDF o imagen. Los formatos soportados son: PDF, PNG, JPG, GIF, BMP, WebP"
                  class="form-control"
                />
              </div>
              
            </group>
            <group>
              <field 
                name="date_to"
                required="1"
                attrs="{'readonly':[('state', 'in' , ('Available', 'Unavailable'))]}"
              />
            </group>
          </group>
          <notebook>
            <page string="Categories">
              <field 
                name="school_menu_detail_ids"
                attrs="{'readonly':[('state', 'in' , ('Available', 'Unavailable'))]}"
              >
                <tree>
                  <field name="day_of_the_week"/>
                  <field name="menu_category_id"/>
                </tree>
              </field>
            </page>            
          </notebook>
          <div class="o_attachment_preview" groups="base.group_user"/>
        </sheet>
      </form>
    </field>
  </record>

  <!--school.menu.detail form-->
  <record id="view_school_menu_detail_form" model="ir.ui.view">
    <field name="name">view_school_menu_detial_form</field>
    <field name="model">school.menu.detail</field>
    <field name="arch" type="xml">
      <form string="Menus">
        <sheet>
         <group>
          <group>
            <field 
              name="day_of_the_week"
              required="1"
            />
            
          </group>
          <group>
            <field 
              name="menu_category_id"
              required="1"
              options="{'no_create':True, 'no_open':True}"
              domain="[('is_menu_category', '=', True)]"
            />
          </group>
         </group>
          <notebook>
            <page string="Products">
              <field name="school_menu_detail_products_ids">
                <tree editable="bottom">
                  <field 
                    name="product_id"
                    required="1"
                    options="{'no_create':True, 'no_open':True}"
                    domain="[('categ_id', '=', parent.menu_category_id)]"
                  />
                  <field name="small_portion_price"/>
                  <field name="large_portion_price"/>
                </tree>
              </field>
            </page>            
          </notebook>
        </sheet>
      </form>
    </field>
  </record>
  <!--school.menu.detail form-->

  <record id="action_school_menu" model="ir.actions.act_window">
    <field name="name">Menu</field>
    <field name="res_model">school.menu</field>
    <field name="view_mode">kanban,tree,form</field>
  </record>

</odoo>

