<odoo>

  <record id="view_gsie_family_form_inherit_add_field" model="ir.ui.view">
    <field name="name">gsie.family.form.inherit.add.field</field>
    <field name="model">gsie.family</field>
    <field name="inherit_id" ref="gsie_english_castle_module.gsie_family_form_view"/>
    <field name="arch" type="xml">
        <field name="name" position="after">
            <field 
                name="related_user_id"
                options="{'no_create':True, 'no_open':True}"
            />
        </field>
        <field name="code" position="after">
            <field 
                name="family_name"
                required="True"
            />
        </field>
    </field>
  </record>

</odoo>