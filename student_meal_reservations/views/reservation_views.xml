<odoo>

  <record id="view_reservation_form" model="ir.ui.view">
    <field name="name">school.meal.reservation.form</field>
    <field name="model">school.meal.reservation</field>
    <field name="arch" type="xml">
      <form string="Meal Reservation">
        <header>
          <button 
            name="confirmOrder" 
            type="object" 
            string="Confirm order"
            states="Draft"
            class="btn-primary"
          />

          <button 
            name="draftOrder" 
            type="object" 
            string="Back to draft"
            states="Confirmed"
          />

          <button 
            name="cancelOrder" 
            type="object" 
            string="Cancel order"
            states="Confirmed"
            class="btn-primary"
          />


					<field name="state" widget="statusbar"/>
        </header>
        <sheet>
          <div class="oe_title">
            <h1>
                <field 
                  name="num_reservation"
                  readonly="1"
                />
            </h1>
          </div>
          <group>
            <group>
              <field 
                name="parent_id"
                readonly="1"
                options="{'no_open':True, 'no_create':True}"
              />

              <field
                name="family_id"
                readonly="1"
                options="{'no_open':True, 'no_create':True}"
                force_save="1"
              />
            </group>
            <group>
              <field 
                name="reservation_date"
                readonly="1"
              />

              <field name="total_pay"/>
            </group>
          </group>
          <notebook>
            <page string="Students">
              <field 
                name="school_meal_reservation_ids"
                attrs="{'readonly': [('state', 'in', ('Confirmed', 'Paid', 'Cancelled'))]}"
              >
                <tree>
                  <field name="student_id"/>
                  <field name="menu_id"/>
                  <field 
                    name="total_pay"
                    sum="total"
                  />
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter">
          <field name="message_ids" widget="mail_thread"/>
        </div>
      </form>
    </field>
  </record>

  <!--school.meal.reservation.students-->
  <record id="view_school_meal_reservation_students_form" model="ir.ui.view">
    <field name="name">view_school_meal_reservation_students_form</field>
    <field name="model">school.meal.reservation.students</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <field name="state" widget="statusbar"/>
        </header>
        <sheet>
          <div class="oe_title">
            <h1>
                <field 
                  name="num_order"
                  readonly="1"
                />
            </h1>
          </div>
          <group>
            <group>
              <field 
                name="student_id"
                required="1"
                options="{'no_open':True, 'no_create':True}"
                domain="[('family_id', '=', parent.family_id)]"
              />

              <field 
                name="day_name"
                invisible="1"
              />

              <field name="total_pay"/>
            </group>
            <group>
              <field 
                name="menu_id"
                required="1"
                options="{'no_open':True, 'no_create':True}"
                domain="[('state', '=', 'Available')]"
              />
            </group>
          </group>
          <notebook>
            <page string="Products">
              <field 
                name="school_meal_reservation_products_ids">
                <tree editable="bottom">
                  <field 
                    name="category_id"
                    required="1"
                    domain="[('school_menu_id', '=', parent.menu_id),
                             ('day_of_the_week', '=', parent.day_name)]"
                    options="{'no_open':True, 'no_create':True}"
                  /> 
                  <field
                    name="product_id"
                    required="1"
                    attrs="{'readonly': [('category_id', '=', False)]}"
                    domain="[('school_menu_detail_id', '=', category_id)]"
                    options="{'no_open':True, 'no_create':True}"
                  />
                  <field
                    name="description"
                    readonly="1"
                    force_save="1"
                  />

                  <!-- <field
                    name="ingredients"
                    readonly="1"
                    force_save="1"
                  />

                  <field
                    name="portion"
                    readonly="1"
                    force_save="1"
                  /> -->
                  
                  <field
                    name="size"
                    required="1"
                    attrs="{'readonly': [('product_id', '=', False)]}"
                  />
                  <field
                    name="price"
                    readonly="1"
                    force_save="1"
                    sum="total"
                  />
                  <field
                    name="quantity"
                    sum="total"
                  />
                  <field 
                    name="total"
                    readonly="1"
                    force_save="1"
                    sum="total"
                  />
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>
  <!--school.meal.reservation.students-->

  <record id="view_reservation_tree" model="ir.ui.view">
    <field name="name">school.meal.reservation.tree</field>
    <field name="model">school.meal.reservation</field>
    <field name="arch" type="xml">
      <tree string="Reservations">
        <field name="num_reservation"/>
        <field name="parent_id"/>
        <field name="family_id"/>
        <field name="reservation_date"/>
        <field name="state"/>
      </tree>
    </field>
  </record>

  <record id="view_reservation_search" model="ir.ui.view">
    <field name="name">view.reservation.search</field>
    <field name="model">school.meal.reservation</field>
    <field name="arch" type="xml">
        <search string="Search Reservations">
            <filter string="Group by State" name="group_state" context="{'group_by': 'state'}"/>
            <filter string="Group by Parent" name="group_parent" context="{'group_by': 'parent_id'}"/>
        </search>
    </field>
  </record>

  <record id="view_meal_reservation_calendar" model="ir.ui.view">
    <field name="name">meal.reservation.calendar</field>
    <field name="model">school.meal.reservation</field>
    <field name="arch" type="xml">
      <calendar 
        string="Meal reservation" 
        date_start="reservation_date" 
        color="state" 
        mode="month" 
        quick_add="False"
      >
        <field name="parent_id"/>
        <field name="reservation_date"/>
        <field name="state"/>
      </calendar>
    </field>
  </record>

  <record id="action_reservation" model="ir.actions.act_window">
    <field name="name">Reservations</field>
    <field name="res_model">school.meal.reservation</field>
    <field name="view_mode">calendar,tree,form</field>
    <field name="domain">[('parent_id', '=', uid)]</field>
  </record>

  <record id="action_reservation_admin" model="ir.actions.act_window">
    <field name="name">Reservations (Admin)</field>
    <field name="res_model">school.meal.reservation</field>
    <field name="search_view_id" ref="view_reservation_search"/>
    <field name="context">{'group_by': ['state', 'parent_id']}</field>
    <field name="view_mode">calendar,tree,form</field>
  </record>

